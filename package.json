{
  "name": "open-task-indicator",
  "version": "0.1.0",
  "description": "Display open task counts in the status bar. Counts unchecked checkboxes across your vault.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit && node esbuild.config.mjs production"
  },
